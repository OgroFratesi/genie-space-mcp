DATABRICKS_HOST=https://<your-workspace>.azuredatabricks.net
DATABRICKS_TOKEN=<your-personal-access-token>
DATABRICKS_GENIE_SPACE_ID_GENERAL=<general-stats-space-id>
DATABRICKS_GENIE_SPACE_ID_MATCH=<match-events-space-id>
DATABRICKS_GENIE_SPACE_ID_PASSES=<passes-space-id>
MCP_SECRET=<a-random-secret-to-protect-your-endpoint>
PORT=3000
X_API_KEY=<twitter-api-key>
X_API_SECRET=<twitter-api-secret>
X_ACCESS_TOKEN=<twitter-access-token>
X_ACCESS_SECRET=<twitter-access-secret>

# AWS ECS Scraper
AWS_REGION=us-east-2
AWS_ACCESS_KEY_ID=<your-iam-user-access-key-id>
AWS_SECRET_ACCESS_KEY=<your-iam-user-secret-access-key>
ECS_CLUSTER=<your-cluster-name-or-arn>
ECS_TASK_DEFINITION=<your-task-definition-family-or-arn>
ECS_CONTAINER_NAME=scrape-app
ECS_SUBNETS=<subnet-id-1>,<subnet-id-2>
ECS_SECURITY_GROUPS=<sg-id>
PROXY_URL=<http://user:pass@host:port>

# Daily tweet pipeline
ANTHROPIC_API_KEY=<your-anthropic-api-key>
NOTION_TOKEN=<your-notion-integration-token>
NOTION_DATABASE_ID=<your-matches-database-id>
NOTION_DRAFT_QUESTIONS_DATABASE_ID=<your-draft-questions-database-id>
NOTION_FLASHBACK_QUESTIONS_DATABASE_ID=<your-flashback-questions-database-id>
NOTION_FLASHBACK_QUESTION_SEEDS_DATABASE_ID=<your-flashback-question-seeds-database-id>
NOTION_FLASHBACK_TWEETS_DATABASE_ID=<your-flashback-tweets-database-id>

# Visualization — Google Drive image hosting
# Service account JSON from GCP (paste full JSON, Railway supports multiline env vars)
GOOGLE_SERVICE_ACCOUNT_JSON=<paste-full-service-account-json>
# Folder ID from the Drive folder URL: drive.google.com/drive/folders/<FOLDER_ID>
# Share this folder with the service account email address
GOOGLE_DRIVE_FOLDER_ID=<your-drive-folder-id>
